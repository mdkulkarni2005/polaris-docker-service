# Polaris — Docker preview (Day 5)
# Copy to your Polaris repo as .env.local

# Your polaris-docker-service deployment (e.g. Railway)
DOCKER_SERVICE_URL=https://your-service.railway.app
# Must match DOCKER_SERVICE_INTERNAL_KEY in polaris-docker-service .env
DOCKER_SERVICE_INTERNAL_KEY=random_secret_string

# Feature flag: "webcontainer" | "docker"
NEXT_PUBLIC_PREVIEW_PROVIDER=webcontainer
